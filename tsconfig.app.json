{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "strictFunctionTypes": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@/*": ["./src/rasyon/*"],
      "@capacitor/core": ["./src/rasyon/stubs/capacitor-core.ts"],
      "@capacitor-community/admob": ["./src/rasyon/stubs/capacitor-admob.ts"],
      "@capacitor/push-notifications": ["./src/rasyon/stubs/capacitor-push.ts"],
      "@sentry/react": ["./src/rasyon/stubs/sentry.ts"],
      "@sentry/aws-serverless": ["./src/rasyon/stubs/sentry.ts"]
    }
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.old.tsx",
    "src/pages/**/*pre_orchestrator*",
    "src/pages/**/*_OLD_*",
    "src/pages/**/*OLD*",
    "src/pages/**/*BACKUP*",
    "src/pages/**/*_old_*",
    "src/pages/_backup_fao_clones/**",
    "src/rasyon/engine/__tests__/**"
  ]
}
