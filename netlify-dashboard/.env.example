# ── Ortam Değişkenleri ─────────────────────────────────────────────────────────
# Bu dosyayı .env olarak kopyalayın ve gerçek API anahtarlarınızı girin.
# .env dosyası git'e eklenmemelidir (.gitignore'a eklenmiştir).

# OpenWeather API Anahtarı (Ücretsiz)
# https://openweathermap.org/appid adresinden ücretsiz API anahtarı alınabilir.
# Anahtar yoksa hava durumu widget'ı sessizce gizlenir; uygulama çalışmaya devam eder.
VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here

# Backend API Base URL (opsiyonel — boş bırakılırsa geliştirmede proxy, üretimde dersbende.com kullanılır)
# VITE_API_BASE=https://dersbende.com
